# Genomics data — never commit large binary files
# Ignore data subdirectories that hold actual sequence/reference files,
# but allow shell scripts and READMEs inside data/ to be tracked.
**/data/reads/
**/data/reference/
results/
*.bam
*.bai
*.cram
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.vcf
*.vcf.gz
*.tbi
*.fa
*.fasta
*.fa.fai
*.dict
*.0123
*.amb
*.ann
*.bwt.2bit.64
*.pac

# Nextflow launcher script (installed to ~/bin, not part of the repo)
/nextflow

# Nextflow
.nextflow/
.nextflow.log*
work/
trace-*.txt
report-*.html
timeline-*.html
dag-*.html

