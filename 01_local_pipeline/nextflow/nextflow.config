// Nextflow configuration for WGS germline variant calling pipeline.
// Two profiles: 'local' (Docker on laptop) and 'healthomics' (AWS HealthOmics).
// Usage:
//   nextflow run main.nf -profile local
//   nextflow run main.nf -profile healthomics

manifest {
    name        = 'wgs-germline'
    description = 'WGS germline variant calling: BWA-MEM2 + GATK4'
    version     = '1.0.0'
    nextflowVersion = '>=24.0'
}

params {
    reads       = null
    reference   = null
    known_sites = null
    outdir      = 'results'
    sample_name = 'sample'
    threads     = 8
}

profiles {

    local {
        docker.enabled    = true
        docker.runOptions = '--rm'
        process.executor  = 'local'

        // Official container images — pulled automatically by Nextflow on first run.
        // bwa-mem2 2.2.1 + samtools 1.17 (mulled BioContainers, same as nf-core/sarek)
        // FastQC 0.12.1, MultiQC 1.21 — BioContainers
        // GATK 4.5.0.0 — Broad Institute official image
        process {
            withName: 'FASTQC'          { container = 'quay.io/biocontainers/fastqc:0.12.1--hdfd78af_0' }
            withName: 'MULTIQC'         { container = 'quay.io/biocontainers/multiqc:1.21--pyhdfd78af_0' }
            withName: 'BWA_MEM2'        { container = 'quay.io/biocontainers/mulled-v2-e5d375990341c5aef3c9aff74f96f66f65375ef6:2cdf6bf1e92acbeb9b2834b1c58754167173a410-0' }
            withName: 'MARK_DUPLICATES' { container = 'broadinstitute/gatk:4.5.0.0' }
            withName: 'BQSR'            { container = 'broadinstitute/gatk:4.5.0.0' }
            withName: 'HAPLOTYPECALLER' { container = 'broadinstitute/gatk:4.5.0.0' }
            withName: 'GENOTYPE_GVCFS'  { container = 'broadinstitute/gatk:4.5.0.0' }
            withName: 'FILTER_VARIANTS' { container = 'broadinstitute/gatk:4.5.0.0' }
        }
    }

    healthomics {
        // AWS HealthOmics uses the 'omics' executor; containers must live in ECR.
        // Use build_and_push.sh --ecr-prefix to retag official images and push to your ECR.
        // Replace the ECR prefix below with your account ID and region.
        process.executor = 'omics'

        process {
            withName: 'FASTQC'          { container = '123456789012.dkr.ecr.us-east-1.amazonaws.com/fastqc:0.12.1'    }
            withName: 'MULTIQC'         { container = '123456789012.dkr.ecr.us-east-1.amazonaws.com/multiqc:1.21'      }
            withName: 'BWA_MEM2'        { container = '123456789012.dkr.ecr.us-east-1.amazonaws.com/bwa-mem2:2.2.1'    }
            withName: 'MARK_DUPLICATES' { container = '123456789012.dkr.ecr.us-east-1.amazonaws.com/gatk:4.5.0.0'      }
            withName: 'BQSR'            { container = '123456789012.dkr.ecr.us-east-1.amazonaws.com/gatk:4.5.0.0'      }
            withName: 'HAPLOTYPECALLER' { container = '123456789012.dkr.ecr.us-east-1.amazonaws.com/gatk:4.5.0.0'      }
            withName: 'GENOTYPE_GVCFS'  { container = '123456789012.dkr.ecr.us-east-1.amazonaws.com/gatk:4.5.0.0'      }
            withName: 'FILTER_VARIANTS' { container = '123456789012.dkr.ecr.us-east-1.amazonaws.com/gatk:4.5.0.0'      }
        }
    }
}
