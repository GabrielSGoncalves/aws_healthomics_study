// Nextflow configuration for WGS germline variant calling pipeline.
// Two profiles: 'local' (Docker on laptop) and 'healthomics' (AWS HealthOmics).
// Usage:
//   nextflow run main.nf -profile local
//   nextflow run main.nf -profile healthomics

manifest {
    name        = 'wgs-germline'
    description = 'WGS germline variant calling: BWA-MEM2 + GATK4'
    version     = '1.0.0'
    nextflowVersion = '>=24.0'
}

params {
    reads       = null
    reference   = null
    known_sites = null
    outdir      = 'results'
    sample_name = 'sample'
    threads     = 8
}

profiles {

    local {
        docker.enabled    = true
        docker.runOptions = '--rm'
        process.executor  = 'local'

        // Local image tags built by containers/build_and_push.sh
        process {
            withName: 'FASTQC'          { container = 'fastqc-multiqc:0.12.1' }
            withName: 'MULTIQC'         { container = 'fastqc-multiqc:0.12.1' }
            withName: 'BWA_MEM2'        { container = 'bwa-mem2:2.2.1'        }
            withName: 'MARK_DUPLICATES' { container = 'gatk:4.5.0.0'          }
            withName: 'BQSR'            { container = 'gatk:4.5.0.0'          }
            withName: 'HAPLOTYPECALLER' { container = 'gatk:4.5.0.0'          }
            withName: 'GENOTYPE_GVCFS'  { container = 'gatk:4.5.0.0'          }
            withName: 'FILTER_VARIANTS' { container = 'gatk:4.5.0.0'          }
        }
    }

    healthomics {
        // AWS HealthOmics uses the 'omics' executor; containers must be in ECR.
        // Replace the ECR prefix with your account and region.
        process.executor = 'omics'

        def ECR = "123456789012.dkr.ecr.us-east-1.amazonaws.com"

        process {
            withName: 'FASTQC'          { container = "${ECR}/fastqc-multiqc:0.12.1" }
            withName: 'MULTIQC'         { container = "${ECR}/fastqc-multiqc:0.12.1" }
            withName: 'BWA_MEM2'        { container = "${ECR}/bwa-mem2:2.2.1"        }
            withName: 'MARK_DUPLICATES' { container = "${ECR}/gatk:4.5.0.0"          }
            withName: 'BQSR'            { container = "${ECR}/gatk:4.5.0.0"          }
            withName: 'HAPLOTYPECALLER' { container = "${ECR}/gatk:4.5.0.0"          }
            withName: 'GENOTYPE_GVCFS'  { container = "${ECR}/gatk:4.5.0.0"          }
            withName: 'FILTER_VARIANTS' { container = "${ECR}/gatk:4.5.0.0"          }
        }
    }
}
